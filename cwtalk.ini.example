; 复制为 cwtalk.ini 放在 CWTalk.exe 同目录后修改。
; 首次运行若无 cwtalk.ini，程序会按代码默认值自动生成。

[Hardware]
CAT_Port=COM3
CAT_Baud=38400
CAT_Address=148
Keying_Port=COM8
Keying_Line=RTS
Keying_ActiveLow=false

[Station]
MY_CALL=BH4XXX
MY_NAME=
MY_QTH=
MY_RIG=IC-7300
Grid=PM01bm
Power=100

[Operation]
Default_WPM=22
CQ_Interval=4
Send_Clear_Delay_Sec=2

[Files]
; 使用相对路径时相对于 exe 所在目录
ADIF_Path=log.adif
CTY_Path=data/cty.dat

[Cat]
Enabled=true
Backend=yaesu
Poll_Interval_Ms=800
Timeout_Ms=1000

[Shortcuts]
F1_Title=CQ
F1_Content=CQ CQ CQ DE <MY_CALL> <MY_CALL> K
F2_Title=
F2_Content=
F3_Title=
F3_Content=
F4_Title=
F4_Content=
F5_Title=
F5_Content=
F6_Title=
F6_Content=
F7_Title=
F7_Content=
F8_Title=
F8_Content=
